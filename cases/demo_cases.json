{
  "name": "Demo API smoke test",
  "base_url": "http://127.0.0.1:19007",
  "variables": {
    "phone": "13800138000",
    "password": "123456",
    "productId": "1001"
  },
  "global_headers": {
    "Accept": "application/json"
  },
  "cases": [
    {
      "name": "login and extract token",
      "method": "POST",
      "path": "/auth/login",
      "json": {
        "phone": "${phone}",
        "password": "${password}"
      },
      "extract": {
        "token": "data.token"
      },
      "assertions": [
        {"type": "status_code", "equals": 200},
        {"type": "json_field_equals", "path": "code", "equals": 200},
        {"type": "json_field_not_empty", "path": "data.token"},
        {"type": "response_time_less_than", "ms": 1000}
      ]
    },
    {
      "name": "query product list",
      "method": "GET",
      "path": "/products",
      "params": {
        "page": 1,
        "pageSize": 10
      },
      "assertions": [
        {"type": "status_code", "equals": 200},
        {"type": "json_field_equals", "path": "code", "equals": 200},
        {"type": "json_field_exists", "path": "data.list.0.name"}
      ]
    },
    {
      "name": "query product detail",
      "method": "GET",
      "path": "/products/detail",
      "params": {
        "productId": "${productId}"
      },
      "assertions": [
        {"type": "status_code", "equals": 200},
        {"type": "json_field_equals", "path": "data.productId", "equals": "${productId}"}
      ]
    },
    {
      "name": "query cart with token",
      "method": "GET",
      "path": "/cart",
      "headers": {
        "Authorization": "Bearer ${token}"
      },
      "assertions": [
        {"type": "status_code", "equals": 200},
        {"type": "json_field_equals", "path": "code", "equals": 200}
      ]
    }
  ]
}
